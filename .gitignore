# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================================================================
# Dependencies
# =============================================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =============================================================================
# Build outputs
# =============================================================================
/.next/
/out/
/build
/coverage

# =============================================================================
# Environment files - NEVER commit these!
# Contains sensitive production credentials (DB, Stripe, API keys)
# =============================================================================
.env
.env.*
.env.local
.env.production
.env.production.local
.env.development
.env.development.local
.env.staging
.env.test

# =============================================================================
# OS & IDE
# =============================================================================
.DS_Store
*.pem
.vercel
.qodo
*.tsbuildinfo
next-env.d.ts

# =============================================================================
# Debug & logs
# =============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.stackdump
logs/

# =============================================================================
# Backup directories - development artifacts, NOT production code
# =============================================================================
/backups/
/backup_dual_role_*/
/src_backup_production/
/config_backup_production/
/prisma_backup_production/
/public_backup_production/
/archived-test-files/
/test_files/
/testing-scripts/

# =============================================================================
# Root-level development scripts & temp files
# These are one-off automation scripts, NOT part of the application
# =============================================================================

# Python scripts (fix_*.py, add_*.py, deploy_*.py, etc.)
/*.py

# Root-level JS files (development utilities)
/*.js

# Root-level shell scripts (keep scripts/ directory)
/*.sh

# Temp text files (debug output, patches, etc.)
/*.txt

# Stale/backup TypeScript files at root (not part of src/)
/*-fixed.ts
/*-fixed.tsx
/*_compact.tsx
/*_fixed.tsx
/clear_session_post.ts
/csrf_hmac.ts
/force_logout_post.ts
/middleware_with_csrf.ts
/secure_health_route.ts
/secure_socket_route.ts

# Misc junk/temp files
/=
*.backup-*

# =============================================================================
# File type exclusions with exceptions
# =============================================================================

# Images - exclude root-level, keep public/ assets
/*.png
*screenshot*.png

# JSON - only track config files
*.json
!package*.json
!tsconfig*.json
!next*.json
!InstaCaresMobile/**/*.json
!src/i18n/locales/*.json

# Markdown - only track docs that matter
*.md
!README.md
!DEPLOYMENT_SAFEGUARDS.md
!.github/**/*.md
!.github/**

# =============================================================================
# Re-include important files/directories
# =============================================================================
!src/**/*.js
!InstaCaresMobile/**/*.js
!scripts/**/*.sh
!public/**/*.png
!public/**/*.jpg
!public/**/*.svg
!public/**/*.ico

# =============================================================================
# Prisma
# =============================================================================
/src/generated/prisma
prisma/dev.db*
prisma/prisma/

# =============================================================================
# Test reports
# =============================================================================
*test-report*.json
*-report-*.json

# Windows reserved filenames
nul
