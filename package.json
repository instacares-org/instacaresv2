{
  "name": "instacares",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3005",
    "dev:ws": "node server.js",
    "build": "next build",
    "build:prod": "next build",
    "start": "next start",
    "start:ws": "NODE_ENV=production node server.js",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:production": "bash scripts/deploy-hostinger.sh",
    "setup:db:dev": "bash scripts/setup-database.sh development",
    "setup:db:staging": "bash scripts/setup-database.sh staging",
    "setup:db:prod": "bash scripts/setup-database.sh production",
    "health-check": "bash scripts/health-check.sh",
    "health-check:prod": "bash scripts/health-check.sh $NEXT_PUBLIC_BASE_URL",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop instacares",
    "pm2:restart": "pm2 restart instacares",
    "pm2:status": "pm2 list",
    "pm2:logs": "pm2 logs instacares",
    "precommit": "npm run lint && npm run type-check",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next && rm -rf node_modules && npm install",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen http://localhost:3005"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.2.0",
    "@mapbox/search-js-core": "^1.3.0",
    "@mapbox/search-js-react": "^1.3.0",
    "@mapbox/search-js-web": "^1.3.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.13.0",
    "@sentry/nextjs": "^10.39.0",
    "@stripe/connect-js": "^3.3.33",
    "@stripe/react-connect-js": "^3.3.33",
    "@stripe/react-stripe-js": "^3.9.0",
    "@stripe/stripe-js": "^7.8.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@types/bcryptjs": "^2.4.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/joi": "^17.2.2",
    "@types/js-cookie": "^3.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "autoprefixer": "^10.4.21",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.1",
    "emoji-picker-react": "^4.16.1",
    "express-rate-limit": "^8.1.0",
    "joi": "^18.0.0",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.539.0",
    "luxon": "^3.7.2",
    "mapbox-gl": "^2.15.0",
    "mysql2": "^3.14.3",
    "next": "^15.5.12",
    "next-auth": "^4.24.11",
    "next-intl": "^4.7.0",
    "node-statsd": "^0.1.1",
    "postcss": "^8.5.6",
    "prisma": "^6.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^7.1.7",
    "recharts": "^3.1.2",
    "resend": "^6.0.1",
    "sharp": "^0.34.3",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^18.4.0",
    "tailwind-merge": "^3.3.1",
    "twilio": "^5.8.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/node": "^4.1.17",
    "@tailwindcss/oxide": "^4.1.17",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.1.17",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/canvas-confetti": "^1.9.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "node-fetch": "^2.7.0",
    "puppeteer": "^24.35.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.3",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
